{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/process-abandoned-carts",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/cron/process-comptabilite",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/monthly-report",
            "schedule": "0 8 1 * *"
        }
    ],
    "headers": [
        {
            "source": "/widget.js",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Robots-Tag", "value": "index, follow" }
            ]
        }
    ]
}
